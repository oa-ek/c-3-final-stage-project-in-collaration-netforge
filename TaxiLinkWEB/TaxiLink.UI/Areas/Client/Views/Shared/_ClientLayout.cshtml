@model TaxiLink.UI.Areas.Client.Models.ClientDashboardViewModel
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TaxiLink</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/client-style.css" />
</head>
<body>
    <div class="top-nav-glass">
        <button id="menu-toggle" class="icon-btn"><i class="fa-solid fa-bars"></i></button>
        <div class="brand-badge">TaxiLink</div>
        <a href="@Url.Action("Profile", "Dashboard", new { area = "Client" })" class="icon-btn avatar-btn text-decoration-none p-0">
            @if (string.IsNullOrEmpty(Model.User.AvatarPath))
            {
                <span>@Model.User.FirstName.Substring(0, 1)</span>
            }
            else
            {
                <img src="@Model.User.AvatarPath" class="w-100 h-100" style="object-fit: cover;" />
            }
        </a>
    </div>

    <div id="sidebar-overlay" class="sidebar-overlay d-none"></div>

    <aside id="sidebar" class="sidebar closed">
        <div class="sidebar-header">
            <h3 class="m-0 text-white">TaxiLink</h3>
            <button id="menu-close" class="icon-btn"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="user-profile-brief mb-4 d-flex align-items-center gap-3">
            <div class="avatar-circle bg-warning text-dark d-flex justify-content-center align-items-center fw-bold fs-4" style="width: 50px; height: 50px; border-radius: 50%; overflow: hidden;">
                @if (string.IsNullOrEmpty(Model.User.AvatarPath))
                {
                    <span>@Model.User.FirstName.Substring(0, 1)</span>
                }
                else
                {
                    <img src="@Model.User.AvatarPath" class="w-100 h-100" style="object-fit: cover;" />
                }
            </div>
            <div>
                <div class="fw-bold fs-5 text-white">@Model.User.FirstName</div>
                <div class="text-warning small">★ @Model.User.Rating.ToString("F1")</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <a href="@Url.Action("Index", "Dashboard", new { area = "Client" })" class="nav-item @(ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")">
                <i class="fa-solid fa-map"></i> Карта
            </a>
            <a href="@Url.Action("Profile", "Dashboard", new { area = "Client" })" class="nav-item @(ViewContext.RouteData.Values["Action"].ToString() == "Profile" ? "active" : "")">
                <i class="fa-solid fa-user"></i> Профіль
            </a>
            <div class="nav-item disabled"><i class="fa-solid fa-clock-rotate-left"></i> Мої поїздки</div>
            <div class="nav-item disabled"><i class="fa-solid fa-credit-card"></i> Способи оплати</div>
            <div class="nav-item disabled"><i class="fa-regular fa-circle-question"></i> Підтримка</div>
            <div class="nav-item disabled"><i class="fa-solid fa-circle-info"></i> Про додаток</div>
        </nav>

        <a href="/Auth/Logout" class="nav-item text-danger mt-auto"><i class="fa-solid fa-arrow-right-from-bracket"></i> Вийти</a>
    </aside>

    @RenderBody()

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/client.js"></script>
</body>
</html>