<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaxiLink Клієнт</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />
    <script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f7f9;
            color: #333;
        }

        .navbar-custom {
            background-color: #1e293b;
            padding: 15px 0;
        }

        .navbar-brand {
            font-weight: 800;
            color: #ffcc00 !important;
            font-size: 24px;
        }

        .main-container {
            padding-top: 30px;
            padding-bottom: 50px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-area="Client" asp-controller="Dashboard" asp-action="Index">
                    TaxiLink <span class="badge bg-warning text-dark fs-6 ms-2">Клієнт</span>
                </a>
                <div class="d-flex">
                    <span class="text-white-50 align-self-center me-3">Привіт, Даша!</span>
                    <a href="/Auth/Logout" class="btn btn-outline-light btn-sm">Вийти</a>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted text-center py-3 border-top bg-white fixed-bottom">
        <div class="container">
            &copy; 2026 - TaxiLink - Кабінет Клієнта (MVP)
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>