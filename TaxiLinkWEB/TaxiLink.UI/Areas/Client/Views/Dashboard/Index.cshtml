@using TaxiLink.Domain.Models
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />

<style>

    #map {
        height: 450px;
        width: 100%;
        border-radius: 20px;
        margin-bottom: 20px;
        border: 2px solid #ddd;
        z-index: 1; 
    }

    .order-panel {
        background: #f8f9fa;
        padding: 25px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
</style>

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Куди їдемо?</h2>

    <div id="map"></div>

    <div class="order-panel">
        <form asp-action="Confirm" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Звідки</label>
                    <input type="text" name="pickup" id="pickup" class="form-control py-3" placeholder="Вул. Хрещатик, 1" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Куди</label>
                    <input type="text" name="dropoff" id="dropoff" class="form-control py-3" placeholder="Аеропорт Бориспіль" required />
                </div>

                <input type="hidden" name="distance" id="distance_input" value="0" />

                <div class="col-12 mt-4">
                    <label class="form-label d-block fw-bold">Оберіть клас авто:</label>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var vc in (IEnumerable<VehicleClass>)ViewBag.VehicleClasses)
                        {
                            <div class="form-check border p-3 rounded-4 flex-fill" style="min-width: 150px; background: white;">
                                <input class="form-check-input ms-0 me-2" type="radio" name="vehicleClassId" value="@vc.Id" id="class_@vc.Id" required>
                                <label class="form-check-label" for="class_@vc.Id">
                                    <strong>@vc.Name</strong><br />
                                    <span class="text-success fw-bold">@vc.BasePrice ₴</span>
                                </label>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-12 text-end mt-4">
                    <button type="submit" class="btn btn-warning btn-lg px-5 py-3 fw-bold shadow">
                        Підтвердити маршрут <i class="fa-solid fa-arrow-right ms-2"></i>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        var map = L.map('map').setView([50.4501, 30.5234], 12);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        var markerA = null;
        var markerB = null;
        window.routeLine = null; 

        async function getAddressFromCoords(lat, lng) {
            try {
                let response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`);
                let data = await response.json();
                if (data.address) {
                    let road = data.address.road || data.address.pedestrian || "Вулиця";
                    let house = data.address.house_number || "";
                    return `${road} ${house}`.trim();
                }
                return data.display_name.split(',')[0];
            } catch (e) {
                return `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
            }
        }

        map.on('click', async function (e) {
            if (!markerA || (markerA && markerB)) {
                if (markerA) map.removeLayer(markerA);
                if (markerB) map.removeLayer(markerB);
                if (window.routeLine) map.removeLayer(window.routeLine);
                markerB = null;

                markerA = L.marker(e.latlng, { icon: L.divIcon({ className: '', html: '<div style="background-color:#10b981; width:16px; height:16px; border-radius:50%; border:2px solid white;"></div>' }) }).addTo(map);
                document.getElementById('pickup').value = "Визначаємо адресу...";
                document.getElementById('pickup').value = await getAddressFromCoords(e.latlng.lat, e.latlng.lng);
            }
            else if (!markerB) {
                markerB = L.marker(e.latlng, { icon: L.divIcon({ className: '', html: '<div style="background-color:#ef4444; width:16px; height:16px; border-radius:50%; border:2px solid white;"></div>' }) }).addTo(map);
                document.getElementById('dropoff').value = "Визначаємо адресу...";
                document.getElementById('dropoff').value = await getAddressFromCoords(e.latlng.lat, e.latlng.lng);
                drawRoute();
            }
        });

        async function drawRoute() {
            if (markerA && markerB) {
                let p1 = markerA.getLatLng();
                let p2 = markerB.getLatLng();

                try {
                    let res = await fetch(`/Client/Dashboard/GetRouteFromCoords?startLat=${p1.lat}&startLon=${p1.lng}&endLat=${p2.lat}&endLon=${p2.lng}`);
                    let data = await res.json();

                    if (data.success) {
                        document.getElementById('distance_input').value = data.distance.toString().replace('.', ',');
                        let routeCoords = data.coordinates.map(c => [c[1], c[0]]);
                        if (window.routeLine) map.removeLayer(window.routeLine);

                        window.routeLine = L.polyline(routeCoords, { color: '#2563eb', weight: 6, opacity: 0.8 }).addTo(map);
                        map.fitBounds(window.routeLine.getBounds(), { padding: [50, 50] });

                    } else {
                        alert("Не вдалося прокласти маршрут між цими точками.");
                    }
                } catch (e) {
                    console.error("Помилка:", e);
                }
            }
        }
    </script>
}