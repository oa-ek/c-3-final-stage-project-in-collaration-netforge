@model TaxiLink.UI.Areas.Driver.Models.DriverOrderViewModel
@{
    ViewData["Title"] = "Поточна робота";
    Layout = "~/Areas/Driver/Views/Shared/_DriverLayout.cshtml";
}

<div class="work-wrapper">
    @if (Model.Id == 0)
    {
        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-center px-4 w-100" style="background-color: #1e293b;">
            <div style="font-size: 60px; color: rgba(255,255,255,0.05); margin-bottom: 20px;"><i class="fa-solid fa-car-on"></i></div>
            <h3 class="fw-bold">Активних замовлень немає</h3>
            <p class="text-muted small">Перейдіть у вкладку "Замовлення", щоб взяти нове.</p>
        </div>
    }
    else
    {
        <div id="map" style="width: 100%; height: 100%;"></div>

        <input type="hidden" id="currentOrderId" value="@Model.Id" />

        <div class="driver-info-sidebar">
            <button id="sidebar-toggle-btn"><i class="fa-solid fa-chevron-left"></i></button>

            <div class="sidebar-content">
                <div class="top-status-pill mb-4" style="background-color: #facc15; color: #1e293b; padding: 10px; border-radius: 10px; text-align: center; font-weight: bold; font-size: 14px;">@Model.StatusName</div>

                <div class="d-flex flex-column gap-3">
                    <div class="route-block" style="position: relative;">
                        <div class="route-line" style="position: absolute; left: 6px; top: 15px; bottom: 15px; width: 2px; background: rgba(255,255,255,0.1);"></div>
                        <div class="route-step mb-3">
                            <div class="step-label text-white-50 small mb-1">Початок маршруту</div>
                            <div class="step-address d-flex align-items-center fw-bold" id="pickup-addr"><div class="dot-start" style="background:#10b981; width:14px; height:14px; border-radius:50%; border:2px solid white; margin-right: 10px;"></div>@Model.PickupAddress</div>
                        </div>
                        <div class="route-step">
                            <div class="step-label text-white-50 small mb-1">Кінець маршруту</div>
                            <div class="step-address d-flex align-items-center fw-bold" id="dropoff-addr"><div class="dot-end" style="background:#ef4444; width:14px; height:14px; border-radius:50%; border:2px solid white; margin-right: 10px;"></div>@Model.DropoffAddress</div>
                        </div>
                    </div>

                    <div class="services-chips d-flex flex-wrap gap-2 p-2 rounded" style="background: rgba(0,0,0,0.2);">
                        <div class="text-muted w-100" style="font-size: 10px; text-transform: uppercase;">Опції замовлення:</div>
                        @if (Model.SelectedServices != null && Model.SelectedServices.Any())
                        {
                            foreach (var srv in Model.SelectedServices)
                            {
                                <span class="badge bg-warning text-dark px-2 py-1 border-0">@srv</span>
                            }
                        }
                        else
                        {
                            <span class="text-white-50" style="font-size: 11px;">Додаткових послуг немає</span>
                        }
                    </div>

                    <div class="passenger-block d-flex justify-content-between align-items-center p-3 rounded" style="background: rgba(0,0,0,0.2);">
                        <div>
                            <div class="passenger-label text-white-50 small">Пасажир</div>
                            <div class="passenger-name text-warning fw-bold fs-5">@Model.PassengerName</div>
                        </div>
                        <div class="action-icons d-flex gap-2">
                            <a href="tel:000" class="icon-btn text-success fs-3"><i class="fa-solid fa-phone"></i></a>
                            <button class="icon-btn text-muted fs-3 border-0 bg-transparent"><i class="fa-solid fa-comment-dots"></i></button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ClientComment))
                    {
                        <div class="comment-box p-3 rounded" style="background: rgba(255, 204, 0, 0.1); border: 1px solid rgba(255, 204, 0, 0.3); font-size: 14px; font-style: italic;">"@Model.ClientComment"</div>
                    }

                    <div class="stats-row border-top border-white border-opacity-10 pt-3">
                        <div class="stat-item mb-2">
                            <div class="label text-white-50 small">Орієнтовний час</div>
                            <div class="val text-success fw-bold fs-5" id="arrival-time">рахуємо...</div>
                        </div>
                        <div class="stat-item">
                            <div class="label text-white-50 small">Вартість</div>
                            <div class="stat-price">
                                <span class="fw-bold fs-2 text-white">@Model.TotalPrice ₴</span><br />
                                <span id="usd-price" style="font-size: 14px; color: #94a3b8; font-weight: 500;"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-2 mt-auto">
                        <button id="btn-cancel" class="btn btn-outline-danger w-100 py-3 fw-bold" data-bs-toggle="modal" data-bs-target="#cancelModal">Скасувати</button>

                        @if (Model.StatusName.Contains("до клієнта") || Model.StatusName.Contains("Прийнято") || Model.StatusName.Contains("В дорозі"))
                        {
                            <button id="btn-start" class="btn btn-warning w-100 py-3 fw-bold text-dark" data-order-id="@Model.Id">Почати поїздку</button>
                        }

                        <button id="btn-finish" class="btn btn-success w-100 py-3 fw-bold text-white" style="display: none;" data-bs-toggle="modal" data-bs-target="#finishModal">Завершити</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary text-white" style="border-radius: 20px;">
            <div class="modal-body p-4">
                <h5 class="fw-bold mb-3 text-center">Скасувати замовлення?</h5>
                <p class="small text-white-50 mb-3 text-center">Буде нараховано штраф згідно з тарифом.</p>
                <select id="cancelReasonId" class="form-select bg-secondary border-0 text-white mb-4 py-2">
                    @if (ViewBag.CancelReasons != null)
                    {
                        foreach (var reason in (IEnumerable<TaxiLink.Domain.Models.CancellationReason>)ViewBag.CancelReasons)
                        {
                            <option value="@reason.Id">@reason.Name</option>
                        }
                    }
                </select>
                <button class="btn btn-danger w-100 py-3 fw-bold" onclick="submitCancel(@Model.Id)">Підтвердити скасування</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="finishModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary text-white text-center" style="border-radius: 25px;">
            <div class="modal-body p-4">
                <div class="display-4 text-warning mb-3"><i class="fa-solid fa-star"></i></div>
                <h5 class="fw-bold mb-1">Поїздка завершена!</h5>
                <p class="text-white-50 small mb-4">Оцініть пасажира @Model.PassengerName</p>

                <div class="d-flex justify-content-center gap-2 mb-4 fs-2 text-warning" id="rating-stars">
                    <i class="fa-regular fa-star cursor-pointer" data-val="1"></i>
                    <i class="fa-regular fa-star cursor-pointer" data-val="2"></i>
                    <i class="fa-regular fa-star cursor-pointer" data-val="3"></i>
                    <i class="fa-regular fa-star cursor-pointer" data-val="4"></i>
                    <i class="fa-solid fa-star cursor-pointer" data-val="5"></i>
                </div>
                <button class="btn btn-warning w-100 py-3 fw-bold text-dark" onclick="submitFinish(@Model.Id)">Надіслати та в Гаманець</button>
            </div>
        </div>
    </div>
</div>