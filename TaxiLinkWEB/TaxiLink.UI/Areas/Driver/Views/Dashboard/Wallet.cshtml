@model TaxiLink.UI.Areas.Driver.Models.WalletViewModel
@{
    ViewData["Title"] = "Гаманець";
    Layout = "~/Areas/Driver/Views/Shared/_DriverLayout.cshtml";
}

<div class="dashboard-wrapper h-100">
    <div class="row h-100 g-4">
        <div class="col-md-4 d-flex flex-column gap-4">
            <div class="glass-card p-4 text-start">
                <div class="text-white-50 small fw-bold text-uppercase mb-2">Баланс гаманця</div>
                <div class="display-5 fw-bold mb-1 text-white" id="current-balance-display">
                    @Model.WalletBalance.ToString("N2") ₴
                </div>
                <div class="text-success small fw-bold mb-4">Доступно до виведення: @Model.WalletBalance.ToString("N2") ₴</div>

                <div class="d-flex flex-column gap-2">
                    <button class="btn btn-warning fw-bold py-3 rounded-3 shadow-warning text-dark" onclick="processWithdrawal()">
                        <i class="fa-solid fa-arrow-down-long me-2"></i> Вивести кошти
                    </button>
                    <button class="btn btn-outline-light py-3 rounded-3 border-opacity-50 text-white" data-bs-toggle="modal" data-bs-target="#refillModal">
                        <i class="fa-solid fa-plus me-2"></i> Поповнити гаманець
                    </button>
                </div>
            </div>

            <div class="glass-card p-4 bg-dark bg-opacity-25">
                <div class="text-white-50 small fw-bold text-uppercase mb-3">Як виводяться зароблені кошти?</div>
                <p class="small text-white-50 mb-0" style="line-height: 1.6;">
                    Оплата за виконані замовлення зараховується на рахунок водія одразу після завершення поїздки...
                </p>
            </div>
        </div> <div class="col-md-8">
            <div class="glass-card p-4 h-100 d-flex flex-column">
                <h4 class="fw-bold mb-4 text-white">Історія транзакцій</h4>
                <div class="transaction-list overflow-auto pe-2" style="flex: 1;">
                    @if (!Model.Transactions.Any())
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-white-50" style="opacity: 0.5;">
                            <i class="fa-solid fa-right-left display-1 mb-3"></i>
                            <h5 class="fw-bold">Історія транзакцій порожня</h5>
                        </div>
                    }
                    else
                    {
                        @foreach (var item in Model.Transactions)
                        {
                            <div class="d-flex align-items-center justify-content-between p-3 mb-2 rounded-3 border-bottom border-white border-opacity-10">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: @(item.IsIncome ? "rgba(16, 185, 129, 0.2)" : "rgba(239, 68, 68, 0.2)"); color: @(item.IsIncome ? "#10b981" : "#ff4d4d")">
                                        <i class="fa-solid @(item.IsIncome ? "fa-arrow-down" : "fa-arrow-up")"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-white small">@item.Title</div>
                                        <div class="text-white-50" style="font-size: 11px;">@item.Date.ToString("dd.MM.yyyy, HH:mm")</div>
                                    </div>
                                </div>
                                <div class="fw-bold @(item.IsIncome ? "text-success" : "text-danger")">
                                    @(item.IsIncome ? "+" : "-") @item.Amount.ToString("N2") ₴
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="refillModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="background: #1e293b; border-radius: 20px;">
            <div class="modal-header border-white border-opacity-10">
                <h5 class="modal-title text-white fw-bold">Поповнення балансу</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="text-white-50 small mb-2">Сума поповнення (₴)</label>
                    <input type="number" id="refillAmount" class="form-control bg-dark border-0 text-white py-3" placeholder="0.00" style="border-radius: 12px;">
                </div>

                <div class="mb-3">
                    <label class="text-white-50 small mb-2">Номер картки</label>
                    <input type="text" class="form-control bg-dark border-0 text-white py-3" placeholder="0000 0000 0000 0000" style="border-radius: 12px;">
                </div>

                <div class="row">
                    <div class="col-6">
                        <label class="text-white-50 small mb-2">Термін дії</label>
                        <input type="text" class="form-control bg-dark border-0 text-white py-3" placeholder="ММ/РР" style="border-radius: 12px;">
                    </div>
                    <div class="col-6">
                        <label class="text-white-50 small mb-2">CVV</label>
                        <input type="password" class="form-control bg-dark border-0 text-white py-3" placeholder="***" style="border-radius: 12px;">
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 p-4">
                <button type="button" id="confirmRefillBtn" class="btn btn-warning w-100 py-3 fw-bold text-dark" style="border-radius: 12px;" onclick="processRefill()">
                    Підтвердити оплату
                </button>
            </div>
        </div>
    </div>
</div>