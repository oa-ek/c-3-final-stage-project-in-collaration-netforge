@using TaxiLink.UI.Admin_areas.Models
@model AdminViewModels.OrderPageViewModel

@{
    ViewData["Title"] = "Замовлення";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title">Історія замовлень</h4>
                <button class="btn btn-sm btn-info" onclick="openOrderModal(0, false)">Створити замовлення</button>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Клієнт</th>
                                <th>Водій</th>
                                <th>Маршрут</th>
                                <th>Статус</th>
                                <th class="text-end">Сума</th>
                                <th class="text-end">Дії</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Orders)
                            {
                                <tr>
                                    <td>#@item.Id</td>
                                    <td class="text-start">@item.PassengerName<br><span class="text-muted small">@item.PassengerPhone</span></td>
                                    <td>@(item.Driver?.User?.FirstName ?? "Пошук...")</td>
                                    <td class="small text-start">@item.PickupAddress<br>↓<br>@item.DropoffAddress</td>
                                    <td>
                                        <span class="badge @(item.OrderStatus?.Name.Contains("Ск") == true ? "bg-danger" : item.OrderStatus?.Name.Contains("Зав") == true ? "bg-success" : "bg-warning text-dark")">
                                            @item.OrderStatus?.Name
                                        </span>
                                    </td>
                                    <td class="text-end fw-bold text-warning">@item.TotalPrice ₴</td>
                                    <td class="text-end">
                                        <button onclick="openOrderModal(@item.Id, true)" class="btn btn-link btn-sm text-info"><i class="fas fa-eye"></i></button>
                                        <button onclick="openOrderModal(@item.Id, false)" class="btn btn-link btn-sm text-warning"><i class="fas fa-pencil-alt"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="orderModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <form id="orderForm" asp-action="UpsertOrder" method="post">
                <input type="hidden" name="Id" id="OrderId" />
                <input type="hidden" name="UserId" id="UserId" />
                <div class="modal-body p-4">
                    <h5 class="fw-bold mb-4" id="modalTitle">Замовлення</h5>
                    <div class="row g-4">
                        <div class="col-md-4">
                            <label>Телефон клієнта</label>
                            <input name="PassengerPhone" id="PassengerPhone" class="form-control mb-2" oninput="searchClient(this.value)" required />
                            <label>Ім'я клієнта</label>
                            <input name="PassengerName" id="PassengerName" class="form-control mb-2" required />
                            <label>Водій</label>
                            <select name="DriverId" id="DriverId" class="form-select mb-2" asp-items="Model.Drivers">
                                <option value="">-- Пошук водія --</option>
                            </select>
                            <label>Статус</label>
                            <select name="OrderStatusId" id="OrderStatusId" class="form-select mb-2" asp-items="Model.Statuses"></select>
                            <div id="cancellationReasonContainer" style="display:none;">
                                <label class="text-danger">Причина скасування</label>
                                <select name="CancellationReasonId" id="CancellationReasonId" class="form-select border-danger mb-2" asp-items="Model.CancellationReasons">
                                    <option value="">-- Оберіть причину --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label>Місто <span id="cityMultiplierBadge" class="badge bg-light text-dark ms-1" style="display:none;"></span></label>
                            <select name="CityId" id="CityId" class="form-select mb-2" asp-items="Model.Cities"></select>
                            <label>Звідки</label>
                            <input name="PickupAddress" id="PickupAddress" class="form-control mb-2" onchange="calcDist()" required />
                            <label>Куди</label>
                            <input name="DropoffAddress" id="DropoffAddress" class="form-control mb-2" onchange="calcDist()" required />
                            <label>Відстань (км)</label>
                            <input name="Distance" id="Distance" type="text" class="form-control mb-2" readonly />
                            <label>Клас авто</label>
                            <select name="VehicleClassId" id="VehicleClassId" class="form-select" asp-items="Model.VehicleClasses"></select>
                        </div>
                        <div class="col-md-4">
                            <label>Оплата</label>
                            <select name="PaymentMethodId" id="PaymentMethodId" class="form-select mb-2" asp-items="Model.PaymentMethods"></select>
                            <label>Промокод</label>
                            <select name="PromoCodeId" id="PromoCodeId" class="form-select mb-2" asp-items="Model.PromoCodes">
                                <option value="">-- Без промокоду --</option>
                            </select>
                            <label>Чайові / Надбавка (₴)</label>
                            <input name="ClientPriceBonus" id="ClientPriceBonus" type="text" class="form-control mb-2" value="0" oninput="updateTotal()" />
                            <label>Послуги</label>
                            <div class="bg-light p-2 rounded mb-2" style="max-height: 100px; overflow-y: auto;">
                                @if (Model.AvailableServices != null)
                                {
                                    foreach (var s in Model.AvailableServices)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input service-check" type="checkbox" name="SelectedServiceIds" value="@s.Id" data-price="@s.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)" id="srv_@s.Id">
                                            <label class="form-check-label">@s.Name (+@s.Price)</label>
                                        </div>
                                    }
                                }
                            </div>
                            <label>Підсумкова сума (₴)</label>
                            <input name="TotalPrice" id="TotalPrice" type="text" class="form-control fs-4 fw-bold text-warning" readonly />
                        </div>
                    </div>
                </div>
                <div class="modal-footer p-4 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Закрити</button>
                    <button type="submit" id="saveBtn" class="btn btn-primary">Зберегти</button>
                </div>
            </form>
        </div>
    </div>
</div>

