<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TaxiLink Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-wrapper">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <i class="fas fa-taxi"></i> TAXILINK
            </div>
            <nav class="sidebar-nav">
                <a href="/Admin/Dashboard" class="nav-item active"><i class="fas fa-chart-pie"></i> Аналітика</a>
                <a href="/Admin/Order" class="nav-item"><i class="fas fa-route"></i> Замовлення</a>
                <a href="/Admin/Fleet" class="nav-item"><i class="fas fa-car"></i> Автопарк</a>
                <a href="/Admin/People" class="nav-item"><i class="fas fa-users"></i> Користувачі</a>
                <a href="/Admin/Marketing" class="nav-item"><i class="fas fa-bullhorn"></i> Маркетинг</a>
                <div class="nav-divider"></div>
                <a href="/Admin/Settings" class="nav-item"><i class="fas fa-cog"></i> Налаштування</a>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-header">
                <span class="page-title">Панель керування</span>
                <div class="user-profile">
                    <span>Admin</span>
                    <div class="avatar">AD</div>
                </div>
            </header>

            <section class="content-body">
                @RenderBody()
            </section>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin-logic.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>