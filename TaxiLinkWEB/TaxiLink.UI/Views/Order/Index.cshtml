@model TaxiLink.UI.Models.AdminViewModels.OrderPageViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Керування замовленнями</h2>
    <button class="btn btn-primary px-4" onclick="openOrderModal(0, false)" style="background-color: #1E3A8A;">
        <i class="fas fa-plus me-2"></i> Створити замовлення
    </button>
</div>

<div class="card border-0 shadow-sm p-4" style="border-radius: 15px;">
    <table class="table align-middle">
        <thead class="text-muted small uppercase">
            <tr>
                <th>ID</th>
                <th>Клієнт</th>
                <th>Водій</th>
                <th>Маршрут</th>
                <th>Статус</th>
                <th>Сума</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Orders)
            {
                <tr>
                    <td class="fw-bold">#@item.Id</td>
                    <td>@item.PassengerName <br /><small class="text-muted">@item.PassengerPhone</small></td>
                    <td>@(item.Driver?.User?.FirstName ?? "Не призначено")</td>
                    <td><span class="small">@item.PickupAddress <i class="fas fa-arrow-right mx-1"></i> @item.DropoffAddress</span></td>
                    <td><span class="badge-status @(item.OrderStatusId == 3 ? "status-completed" : "status-progress")">@item.OrderStatus?.Name</span></td>
                    <td class="fw-bold">@item.TotalPrice ₴</td>
                    <td class="text-end">
                        <button onclick="openOrderModal(@item.Id, true)" class="btn btn-link text-muted p-1"><i class="fas fa-eye"></i></button>
                        <button onclick="openOrderModal(@item.Id, false)" class="btn btn-link text-muted p-1"><i class="fas fa-pencil-alt"></i></button>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Видалити замовлення назавжди?');">
                            <button type="submit" class="btn btn-link text-danger p-1"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="orderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <form id="orderForm" asp-action="Upsert" method="post">
                <input type="hidden" name="Id" id="OrderId" />
                <input type="hidden" name="UserId" id="UserId" />

                <div class="modal-body p-4">
                    <h4 class="fw-bold mb-4" id="modalTitle">Замовлення</h4>
                    <div class="row g-4">
                        <div class="col-md-4">
                            <h6 class="fw-bold text-primary mb-3">Клієнт та Водій</h6>
                            <label class="small fw-bold text-muted">Телефон</label>
                            <input name="PassengerPhone" id="PassengerPhone" class="form-control bg-light border-0 mb-2" oninput="searchClient(this.value)" required />

                            <label class="small fw-bold text-muted">Ім'я</label>
                            <input name="PassengerName" id="PassengerName" class="form-control bg-light border-0 mb-2" required />

                            <label class="small fw-bold text-muted">Водій</label>
                            <select name="DriverId" id="DriverId" class="form-select bg-light border-0 mb-2" asp-items="Model.Drivers">
                                <option value="">-- Оберіть водія --</option>
                            </select>

                            <label class="small fw-bold text-muted">Статус замовлення</label>
                            <select name="OrderStatusId" id="OrderStatusId" class="form-select bg-light border-0 mb-2" asp-items="Model.Statuses"></select>

                            <label class="small fw-bold text-muted">Клас авто</label>
                            <select name="VehicleClassId" id="VehicleClassId" class="form-select bg-light border-0" asp-items="Model.VehicleClasses"></select>
                        </div>

                        <div class="col-md-4 border-start border-end px-4">
                            <h6 class="fw-bold text-primary mb-3">Маршрут</h6>
                            <label class="small fw-bold text-muted">Місто</label>
                            <select name="CityId" id="CityId" class="form-select bg-light border-0 mb-2" asp-items="Model.Cities"></select>

                            <label class="small fw-bold text-muted">Звідки</label>
                            <input name="PickupAddress" id="PickupAddress" class="form-control bg-light border-0 mb-2" onchange="calcDist()" required />

                            <label class="small fw-bold text-muted">Куди</label>
                            <input name="DropoffAddress" id="DropoffAddress" class="form-control bg-light border-0 mb-2" onchange="calcDist()" required />

                            <label class="small fw-bold text-muted">Відстань (км)</label>
                            <input name="Distance" id="Distance" type="text" class="form-control bg-light border-0" readonly />
                        </div>

                        <div class="col-md-4">
                            <h6 class="fw-bold text-primary mb-3">Оплата</h6>
                            <label class="small fw-bold text-muted">Метод оплати</label>
                            <select name="PaymentMethodId" id="PaymentMethodId" class="form-select bg-light border-0 mb-2" asp-items="Model.PaymentMethods"></select>

                            <label class="small fw-bold text-muted">Націнка (₴)</label>
                            <input name="ClientPriceBonus" id="ClientPriceBonus" type="text" class="form-control bg-light border-0 mb-2" value="0" oninput="updateTotal()" />

                            <label class="small fw-bold text-muted">Сума (₴)</label>
                            <input name="TotalPrice" id="TotalPrice" type="text" class="form-control bg-light border-0 fw-bold fs-5" readonly />

                            <label class="small fw-bold text-muted mt-2">Послуги</label>
                            <div class="bg-light p-2 rounded" style="max-height: 120px; overflow-y: auto;">
                                @foreach (var s in Model.AvailableServices)
                                {
                                    <div class="form-check small">
                                        <input class="form-check-input service-check" type="checkbox" name="SelectedServiceIds" value="@s.Id" data-price="@s.Price" id="srv_@s.Id">
                                        <label class="form-check-label">@s.Name (+@s.Price ₴)</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="small fw-bold text-muted">Коментар</label>
                        <textarea name="ClientComment" id="ClientComment" class="form-control bg-light border-0" rows="2"></textarea>
                    </div>
                </div>

                <div class="modal-footer border-0 p-4">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Закрити</button>
                    <button type="submit" id="saveBtn" class="btn btn-primary px-5" style="background-color: #1E3A8A;">Зберегти</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function searchClient(phone) {
        if (phone.length >= 10) {
            $.get('/Order/GetUserDetails?phone=' + phone, function(res) {
                if (res.exists) {
                    $('#PassengerName').val(res.fullName);
                    $('#UserId').val(res.id);
                } else {
                    $('#UserId').val(0);
                }
            });
        }
    }

    function calcDist() {
        if ($('#PickupAddress').val() && $('#DropoffAddress').val()) {
            const d = (Math.random() * 8 + 3).toFixed(1);
            $('#Distance').val(d.replace('.', ','));
            updateTotal();
        }
    }

    function updateTotal() {
        const dStr = $('#Distance').val() ? $('#Distance').val().replace(',', '.') : "0";
        const bStr = $('#ClientPriceBonus').val() ? $('#ClientPriceBonus').val().replace(',', '.') : "0";

        const d = parseFloat(dStr) || 0;
        const b = parseFloat(bStr) || 0;
        let servicesPrice = 0;

        $('.service-check:checked').each(function() {
            const pStr = $(this).data('price').toString().replace(',', '.');
            servicesPrice += parseFloat(pStr) || 0;
        });

        const total = (d * 15) + b + servicesPrice;
        $('#TotalPrice').val(total.toFixed(2).replace('.', ','));
    }

    function openOrderModal(id, viewOnly) {
        $('#orderForm')[0].reset();
        $('#TotalPrice').val("0,00");
        $('#Distance').val("0,0");
        $('.service-check').prop('checked', false);

        $('#OrderId').val(id);
        $('#saveBtn').show();
        $('#orderForm input, #orderForm select, #orderForm textarea').prop('disabled', false);
        $('#Distance, #TotalPrice').prop('readonly', true);

        if (id === 0) {
            $('#modalTitle').text('Нове замовлення');
            $('#OrderStatusId').val(1);
        } else {
            $.get('/Order/GetOrderDetails/' + id, function(res) {
                const data = res.order;

                $('#OrderId').val(data.id);
                $('#UserId').val(data.userId);
                $('#PassengerPhone').val(data.passengerPhone);
                $('#PassengerName').val(data.passengerName);
                $('#DriverId').val(data.driverId);
                $('#VehicleClassId').val(data.vehicleClassId);
                $('#CityId').val(data.cityId);
                $('#PickupAddress').val(data.pickupAddress);
                $('#DropoffAddress').val(data.dropoffAddress);
                $('#Distance').val(data.distance ? data.distance.toString().replace('.', ',') : "0");
                $('#PaymentMethodId').val(data.paymentMethodId);
                $('#ClientPriceBonus').val(data.clientPriceBonus ? data.clientPriceBonus.toString().replace('.', ',') : "0");
                $('#TotalPrice').val(data.totalPrice ? data.totalPrice.toString().replace('.', ',') : "0");
                $('#OrderStatusId').val(data.orderStatusId);
                $('#ClientComment').val(data.clientComment);

                if (res.serviceIds) {
                    res.serviceIds.forEach(srvId => {
                        $('#srv_' + srvId).prop('checked', true);
                    });
                }

                if (viewOnly) {
                    $('#modalTitle').text('Перегляд замовлення #' + id);
                    $('#saveBtn').hide();
                    $('#orderForm input, #orderForm select, #orderForm textarea').prop('disabled', true);
                } else {
                    $('#modalTitle').text('Редагування замовлення #' + id);
                }
            });
        }

        $('#orderModal').modal('show');
    }

    $(document).ready(function () {
        $(document).on('change', '.service-check', function () {
            updateTotal();
        });
    });
</script>