@model TaxiLink.UI.Models.RegisterViewModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Реєстрація - TaxiLink</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/auth-custom.css" asp-append-version="true" />
</head>
<body>
    <div class="container d-flex justify-content-center px-3">
        <div class="glass-card" style="max-width: 650px;">
            <div class="text-center mb-4">
                <h4 class="text-taxi fw-bold mb-2">TaxiLink</h4>
                <h2 class="fw-bold">Приєднуйтесь до нас</h2>
            </div>
            <form asp-controller="Auth" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small text-center"></div>
                <div class="role-toggle">
                    <input type="radio" id="rolePassenger" name="RoleId" value="3" checked />
                    <label for="rolePassenger">Я Пасажир</label>
                    <input type="radio" id="roleDriver" name="RoleId" value="2" />
                    <label for="roleDriver">Я Водій</label>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="input-icon-wrapper m-0">
                            <i class="fa-regular fa-user left-icon"></i>
                            <input asp-for="FirstName" class="form-control" placeholder="Ім'я" />
                        </div>
                        <span asp-validation-for="FirstName" class="text-danger small d-block mt-1"></span>
                    </div>
                    <div class="col-md-6">
                        <div class="input-icon-wrapper m-0">
                            <i class="fa-regular fa-user left-icon"></i>
                            <input asp-for="LastName" class="form-control" placeholder="Прізвище" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="input-icon-wrapper m-0">
                            <i class="fa-solid fa-phone left-icon"></i>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Номер телефону" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small d-block mt-1"></span>
                    </div>
                    <div class="col-md-6">
                        <div class="input-icon-wrapper m-0">
                            <i class="fa-regular fa-envelope left-icon"></i>
                            <input asp-for="Email" class="form-control" placeholder="Електронна пошта" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                    </div>
                    <div class="col-md-6">
                        <div class="input-icon-wrapper m-0">
                            <i class="fa-solid fa-lock left-icon"></i>
                            <input asp-for="Password" class="form-control" placeholder="Створити пароль" />
                            <i class="fa-regular fa-eye right-icon toggle-password"></i>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                    </div>
                    <div class="col-md-6">
                        <div class="input-icon-wrapper m-0">
                            <i class="fa-solid fa-shield left-icon"></i>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Підтвердити пароль" />
                            <i class="fa-regular fa-eye right-icon toggle-password"></i>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
                    </div>
                </div>
                <button type="submit" class="btn btn-taxi w-100 mt-4 mb-3">Створити акаунт</button>
                <div class="divider">Швидка реєстрація</div>
                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <a asp-action="GoogleLogin" class="social-btn"><i class="fab fa-google text-danger me-2"></i> Google</a>
                    </div>
                    <div class="col-6">
                        <a asp-action="FacebookLogin" class="social-btn"><i class="fab fa-facebook text-primary me-2"></i> Facebook</a>
                    </div>
                </div>
                <div class="text-center opacity-75 small">
                    Вже є акаунт? <a asp-action="Login" class="text-taxi fw-bold fs-6">Увійти</a>
                </div>
            </form>
        </div>
    </div>
    <script src="~/js/auth-logic.js" asp-append-version="true"></script>
</body>
</html>