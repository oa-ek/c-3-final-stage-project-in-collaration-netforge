@model TaxiLink.UI.Models.RegisterViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Реєстрація - TaxiLink</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body {
            background: linear-gradient(rgba(15, 23, 42, 0.8), rgba(15, 23, 42, 0.9)), url('/img/city-bg.jpg') no-repeat center center fixed;
            background-size: cover;
            color: white;
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px 0;
        }

        .glass-card {
            background: rgba(30, 35, 45, 0.4);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            padding: 40px;
            width: 100%;
            max-width: 600px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .text-taxi {
            color: #FFCC00;
            text-decoration: none;
        }
        .role-toggle {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 5px;
            display: flex;
            margin-bottom: 25px;
        }

            .role-toggle input[type="radio"] {
                display: none;
            }

            .role-toggle label {
                flex: 1;
                text-align: center;
                padding: 10px;
                border-radius: 8px;
                cursor: pointer;
                color: #8a8d93;
                transition: all 0.3s ease;
                margin: 0;
                font-weight: 500;
            }

            .role-toggle input[type="radio"]:checked + label {
                background-color: #FFCC00;
                color: #1e293b;
            }

        .input-icon-wrapper {
            position: relative;
            margin-bottom: 1rem;
        }

            .input-icon-wrapper i.left-icon {
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: #8a8d93;
            }

            .input-icon-wrapper i.right-icon {
                position: absolute;
                right: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: #8a8d93;
                cursor: pointer;
            }

        .form-control {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            border-radius: 12px;
            padding: 14px 15px 14px 45px;
        }

            .form-control::placeholder {
                color: #8a8d93;
            }

            .form-control:focus {
                background: rgba(255, 255, 255, 0.08);
                border-color: #FFCC00;
                color: white;
                box-shadow: 0 0 0 0.2rem rgba(255, 204, 0, 0.25);
            }

        .btn-taxi {
            background-color: #FFCC00;
            color: #1e293b;
            font-weight: 600;
            border-radius: 12px;
            padding: 14px;
            border: none;
            transition: 0.3s;
        }

            .btn-taxi:hover {
                background-color: #e6b800;
            }

        .terms-text {
            font-size: 0.75rem;
            color: #8a8d93;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center">
        <div class="glass-card">
            <div class="text-center mb-4">
                <h4 class="text-taxi fw-bold mb-2">TaxiLink</h4>
                <h2 class="fw-bold">Приєднуйтесь до TaxiLink</h2>
            </div>

            <form asp-controller="Auth" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="role-toggle">
                    <input type="radio" id="rolePassenger" name="RoleId" value="3" checked />
                    <label for="rolePassenger">Пасажир</label>

                    <input type="radio" id="roleDriver" name="RoleId" value="2" />
                    <label for="roleDriver">Водій</label>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="input-icon-wrapper">
                            <i class="fa-regular fa-user left-icon"></i>
                            <input asp-for="FirstName" class="form-control" placeholder="Ім'я" />
                        </div>
                        <span asp-validation-for="FirstName" class="text-danger small d-block mb-2"></span>
                    </div>
                    <div class="col-md-6">
                        <div class="input-icon-wrapper">
                            <i class="fa-regular fa-user left-icon"></i>
                            <input asp-for="LastName" class="form-control" placeholder="Прізвище" />
                        </div>
                    </div>
                </div>

                <div class="input-icon-wrapper">
                    <i class="fa-solid fa-phone left-icon"></i>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Номер телефону" />
                </div>
                <span asp-validation-for="PhoneNumber" class="text-danger small d-block mb-2"></span>

                <div class="input-icon-wrapper">
                    <i class="fa-regular fa-envelope left-icon"></i>
                    <input asp-for="Email" class="form-control" placeholder="Електронна пошта" />
                </div>
                <span asp-validation-for="Email" class="text-danger small d-block mb-2"></span>

                <div class="row">
                    <div class="col-md-6">
                        <div class="input-icon-wrapper">
                            <i class="fa-solid fa-lock left-icon"></i>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Створити пароль" />
                            <i class="fa-regular fa-eye right-icon"></i>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small d-block mb-2"></span>
                    </div>
                    <div class="col-md-6">
                        <div class="input-icon-wrapper">
                            <i class="fa-solid fa-lock left-icon"></i>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Підтвердити пароль" />
                            <i class="fa-regular fa-eye right-icon"></i>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mb-4"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-taxi w-100 mb-4">Створити акаунт</button>

                <p class="terms-text mb-4">
                    Створюючи акаунт, ви погоджуєтесь з нашими
                    <a href="#" class="text-taxi">Умовами використання</a> та
                    <a href="#" class="text-taxi">Політикою конфіденційності</a>.
                </p>

                <div class="text-center opacity-75 small">
                    Вже є акаунт? <a asp-action="Login" class="text-taxi fw-bold">Увійти</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>