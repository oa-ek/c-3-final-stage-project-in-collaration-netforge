@model TaxiLink.UI.Models.ForgotPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Відновлення пароля - TaxiLink</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/auth-custom.css" asp-append-version="true" />
</head>
<body>
    <div class="container d-flex justify-content-center px-3">
        <div class="glass-card text-center" style="max-width: 450px;">
            <div style="width: 80px; height: 80px; background: rgba(255,204,0,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                <i class="fa-solid fa-unlock-keyhole fa-2x text-taxi"></i>
            </div>
            <h3 class="fw-bold mb-3">Забули пароль?</h3>
            <p class="opacity-75 mb-4 small">Введіть email, пов'язаний з вашим акаунтом, і ми надішлемо інструкції з відновлення.</p>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-success border-0" style="background: rgba(40, 167, 69, 0.15); color: #4ade80; border-radius: 12px;">
                    @ViewBag.Message
                </div>
            }
            else
            {
                <form asp-action="ForgotPassword" method="post">
                    <div class="input-icon-wrapper mb-2">
                        <i class="fa-regular fa-envelope left-icon"></i>
                        <input asp-for="Email" class="form-control text-center px-4" placeholder="Введіть ваш Email" required />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small d-block mb-4"></span>
                    <button type="submit" class="btn btn-taxi">Відправити інструкцію</button>
                </form>
            }
            <div class="mt-5">
                <a asp-action="Login" class="text-taxi fw-bold"><i class="fa-solid fa-arrow-left me-2"></i> Повернутися до входу</a>
            </div>
        </div>
    </div>
    <script src="~/js/auth-logic.js" asp-append-version="true"></script>
</body>
</html>
