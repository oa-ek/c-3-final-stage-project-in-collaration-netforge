@model TaxiLink.UI.Models.ResetPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Новий пароль - TaxiLink</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/auth-custom.css" asp-append-version="true" />
</head>
<body>
    <div class="container d-flex justify-content-center px-3">
        <div class="glass-card text-center" style="max-width: 450px;">
            <div style="width: 80px; height: 80px; background: rgba(255,204,0,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                <i class="fa-solid fa-shield-check fa-2x text-taxi"></i>
            </div>
            <h3 class="fw-bold mb-2">Створення пароля</h3>
            <p class="opacity-75 mb-4 small">Придумайте надійний пароль для вашого акаунту.</p>

            <form asp-action="ResetPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="Email" />

                <div class="input-icon-wrapper mb-2">
                    <i class="fa-solid fa-lock left-icon"></i>
                    <input asp-for="NewPassword" class="form-control" placeholder="Новий пароль" required />
                    <i class="fa-regular fa-eye right-icon toggle-password"></i>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small d-block mb-3"></span>

                <div class="input-icon-wrapper mb-2">
                    <i class="fa-solid fa-lock left-icon"></i>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Підтвердіть пароль" required />
                    <i class="fa-regular fa-eye right-icon toggle-password"></i>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mb-4"></span>

                <button type="submit" class="btn btn-taxi">Зберегти пароль</button>
            </form>
        </div>
    </div>
    <script src="~/js/auth-logic.js" asp-append-version="true"></script>
</body>
</html>