@model TaxiLink.UI.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вхід - TaxiLink</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/auth-custom.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-wrapper row w-100 m-0">
        <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-center p-5">
            <h1 class="text-taxi fw-bold mb-4 display-3">TaxiLink</h1>
            <img src="https://images.unsplash.com/photo-1494976388531-d1058494cdd8?auto=format&fit=crop&w=1200&q=80" class="premium-img mb-4" />
            <p class="opacity-75 fs-4">Преміум сервіс таксі для сучасного міста.</p>
        </div>
        <div class="col-lg-6">
            <div class="glass-card">
                <h2 class="fw-bold mb-2">З поверненням у TaxiLink</h2>
                <p class="opacity-50 mb-5">Ваша поїздка на відстані одного кліку.</p>
                <form asp-controller="Auth" asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                    <div class="input-icon-wrapper">
                        <i class="fa-regular fa-envelope left-icon"></i>
                        <input asp-for="Email" class="form-control" placeholder="Електронна пошта" required />
                    </div>
                    <div class="input-icon-wrapper">
                        <i class="fa-solid fa-lock left-icon"></i>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Пароль" required />
                        <i class="fa-regular fa-eye right-icon toggle-password"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check m-0">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label opacity-75 small">Запам'ятати мене</label>
                        </div>
                        <a asp-action="ForgotPassword" class="text-taxi small fw-bold">Забули пароль?</a>
                    </div>
                    <button type="submit" class="btn btn-taxi">Увійти</button>
                    <div class="divider">Або увійдіть через</div>
                    <div class="row g-3">
                        <div class="col-6">
                            <a asp-action="GoogleLogin" class="social-btn"><i class="fab fa-google text-danger me-2"></i> Google</a>
                        </div>
                        <div class="col-6">
                            <a asp-action="FacebookLogin" class="social-btn"><i class="fab fa-facebook text-primary me-2"></i> Facebook</a>
                        </div>
                    </div>
                    <div class="text-center mt-5 opacity-75 small">
                        Немає акаунту? <a asp-action="Register" class="text-taxi fw-bold fs-6">Зареєструватися</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="~/js/auth-logic.js" asp-append-version="true"></script>
</body>
</html>